fact wscript_strings {
  title    = "wscript: string methods"
  related  = [wscript_types, wscript_collections]
  audience = :both
  body {
    p "Strings are immutable; methods return new values."
    p <<PROSE
`len bytes_len is_empty split trim trim_start trim_end to_upper to_lower
starts_with ends_with contains find replace repeat pad_left pad_right chars
slice parse_int parse_float`.
PROSE
  }
}
