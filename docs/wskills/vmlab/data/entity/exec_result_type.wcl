entity exec_result_type {
  name     = "ExecResult"
  kind     = "wscript data type"
  summary  = "The result of a guest command run via vm.exec: exit_code, stdout, stderr."
  related  = [vm_api, vm_agent]
  audience = :both
  body {
    p "Returned by the guest-agent exec methods (`vm.exec`, `vm.exec_timeout`)."
    code "rust" { source = <<'SRC'
struct ExecResult { exit_code: int, stdout: string, stderr: string }
SRC
    }
  }
}
