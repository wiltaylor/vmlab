// Skill projection — a Claude Code skill folder over the wskill data model.
//
// Build:  wcl wdoc skill wdoc/skill/main.wcl --out out/skill
//
// The start page becomes SKILL.md; every other page lands under references/.
// SKILL.md's body is the shared `skill_md_body` component (component/skill_md.wcl)
// — it inlines the curated `:ai`/`:both` indexes, linking each pinned note's page
// directly, so there are no per-kind reference index pages. The same component
// renders the book's skill preview (pages/skill_links.wcl), so the preview can't
// drift. vmlab appends its own non-unit reference pages (CLI / glossary / related
// / bundled files) below the inlined indexes.

import <wdoc.wcl>
import "../../wskill.wcl"
import "../component/common.wcl"    // UnitRef + shared per-unit sub-sections
import "../component/skill_md.wcl"  // skill_md_body (shared with the preview)
import "../component/concept.wcl"   // concept_body
import "../component/entity.wcl"    // entity_body
import "../component/fact.wcl"      // fact_body
import "../component/process.wcl"   // process_body
import "../component/type_index.wcl" // shared unit-index page component

// The single topic block, bound from its gather list (see base.wcl).
let topic = head(topics)
let skill = head(skills)

// Skill artifacts are authored as children of the skill block (base.wcl).
let skill_scripts = skill.skill_scripts
let skill_assets  = skill.skill_assets

// Audience filter — keep the skill lean. Each `let` shadows the gathered list of
// the same name with its "both"/"ai" subset (dropping book-only blocks).
let in_skill   = fn(a: Audience) -> bool { match a { :book => false, _ => true } }
let concepts   = filter(concepts,   fn(c: Concept)   -> bool { in_skill(c.audience) })
let entities   = filter(entities,   fn(e: Entity)    -> bool { in_skill(e.audience) })
let facts      = filter(facts,      fn(f: Fact)      -> bool { in_skill(f.audience) })
let terms      = filter(terms,      fn(t: Term)      -> bool { in_skill(t.audience) })
let examples   = filter(examples,   fn(x: Example)   -> bool { in_skill(x.audience) })
let indexes    = filter(indexes,    fn(x: Index)      -> bool { in_skill(x.audience) })
let procedures = filter(procedures, fn(p: Procedure) -> bool { in_skill(p.audience) })
// Opt-in cli module (schema/cli.wcl): the cli(s) that belong in the skill.
let clis       = filter(clis,       fn(x: Cli)       -> bool { in_skill(x.audience) })

// Flattened cross-reference rows over the skill's audience-filtered units, so a
// unit's `related` ids resolve to links (UnitRef + the components live in
// component/common.wcl).
let all_units = flatten([
  map(concepts,   fn(c: Concept)   -> UnitRef { { id: c.id, name: c.name,  href: $"concept_${c.id}", related: c.related } }),
  map(entities,   fn(e: Entity)    -> UnitRef { { id: e.id, name: e.name,  href: $"entity_${e.id}",  related: e.related } }),
  map(facts,      fn(f: Fact)      -> UnitRef { { id: f.id, name: f.title, href: $"fact_${f.id}",    related: f.related } }),
  map(procedures, fn(p: Procedure) -> UnitRef { { id: p.id, name: p.title, href: $"process_${p.id}", related: p.related } }),
])

// Gate helper: [true] when non-empty, else [] — for one-shot conditional blocks.
let bundled_count = len(skill_scripts) + len(skill_assets)

site skill {
  default_template = :ai_skill
  skill {
    name        = $"${topic.name}"
    description = $"Reference and processes for ${topic.name}. ${topic.summary} Use when working with ${topic.name} or answering questions about it."
    // license  = "MIT"   // optional; written to SKILL.md front matter
  }
}

// --- SKILL.md (start page) --------------------------------------------------

page index { sites = [:skill]  start = true
  // Static frontmatter: the base-schema version + skill controls.
  @schemaless frontmatter {
    wskill_schema_version = $"${schema_version}"
    "allowed-tools"            = skill.allowed_tools
    "disallowed-tools"         = skill.disallowed_tools
    "disable-model-invocation" = skill.disable_model_invocation
  }
  // Topic header, overview, parameters, boundary, then the curated indexes
  // inlined (each links its pinned notes directly).
  skill_md_body { topic = topic  skill = skill  indexes = indexes  concepts = concepts  entities = entities  facts = facts  procedures = procedures  extra_refs = [] }

  // vmlab's non-unit reference pages, appended under the same Reference section.
  wdoc_repeater { each = match len(clis) { 0 => [], _ => [true] }  as = :_cli
    p "- [CLI reference](cli_ref) — every `vmlab` subcommand, its arguments and switches." }
  p "- [Glossary](glossary_ref) — terms and definitions."
  p "- [Related skills](related_ref) — cross-references to other wskills."
  wdoc_repeater { each = match bundled_count { 0 => [], _ => [true] }  as = :_bf
    p "- [Bundled files](assets_ref) — scripts and data shipped with this skill." }
}

// --- Per-unit pages — one per unit, each delegating to a shared component ----

wdoc_repeater { each = concepts  as = :c
  page $"concept_${c.id}" { sites = [:skill]  title = $"${c.name}"
    concept_body { unit = c  examples = examples  all_units = all_units  backlinks = []
      p "[← Back to SKILL.md](index)"
    }
  }
}

wdoc_repeater { each = entities  as = :e
  page $"entity_${e.id}" { sites = [:skill]  title = $"${e.name}"
    entity_body { unit = e  examples = examples  all_units = all_units  backlinks = []
      p "[← Back to SKILL.md](index)"
    }
  }
}

wdoc_repeater { each = facts  as = :f
  page $"fact_${f.id}" { sites = [:skill]  title = $"${f.title}"
    fact_body { unit = f  examples = examples  all_units = all_units  backlinks = []
      p "[← Back to SKILL.md](index)"
    }
  }
}

wdoc_repeater { each = procedures  as = :pr
  page $"process_${pr.id}" { sites = [:skill]  title = $"${pr.title}"
    process_body { unit = pr  all_units = all_units  step_style = "skill"  backlinks = []
      p "[← Back to SKILL.md](index)"
    }
  }
}

// --- references/cli_ref.md — the vmlab CLI command reference (opt-in cli module) -
page cli_ref { sites = [:skill]  title = "CLI reference"
  wdoc_repeater { each = clis  as = :c
    h1 $"${c.name} — CLI reference"
    wdoc_repeater { each = match c.description { none => [], d => [d] }  as = :d  p $"${d}" }
    wdoc_repeater { each = match len(c.switches) { 0 => [], _ => [true] }  as = :_gs
      h2 "Global switches"
      table { header = ["Switch", "Value", "Description"]  rows = map(c.switches, fn(sw: CliSwitch) -> list<utf8> { [$"${match sw.short { none => "", s => $"${s}, " }}${sw.long}", sw.value_name ?? "—", sw.description ?? "—"] }) }
    }
    wdoc_repeater { each = c.subcommands  as = :sc
      h2 $"${c.name} ${sc.name}"
      wdoc_repeater { each = match len(sc.aliases) { 0 => [], _ => [true] }  as = :_al  p $"_alias: ${join(sc.aliases, ", ")}_" }
      wdoc_repeater { each = match sc.description { none => [], d => [d] }  as = :d  p $"${d}" }
      wdoc_repeater { each = match len(sc.args) { 0 => [], _ => [true] }  as = :_a
        table { header = ["Argument", "Required", "Description"]  rows = map(sc.args, fn(a: CliArg) -> list<utf8> { [$"${a.name}${match a.variadic { true => "…", _ => "" }}", match a.required { true => "required", _ => "optional" }, a.description ?? "—"] }) }
      }
      wdoc_repeater { each = match len(sc.switches) { 0 => [], _ => [true] }  as = :_s
        table { header = ["Switch", "Value", "Description"]  rows = map(sc.switches, fn(sw: CliSwitch) -> list<utf8> { [$"${match sw.short { none => "", s => $"${s}, " }}${sw.long}", sw.value_name ?? "—", sw.description ?? "—"] }) }
      }
      wdoc_repeater { each = sc.examples  as = :ex  code $"${ex.lang ?? "text"}" { source = ex.code } }
      wdoc_repeater { each = match sc.remarks { none => [], r => [r] }  as = :r  p $"**Remarks:** ${r}" }
      wdoc_repeater { each = sc.subcommands  as = :ns
        h3 $"${c.name} ${sc.name} ${ns.name}"
        wdoc_repeater { each = match len(ns.aliases) { 0 => [], _ => [true] }  as = :_al  p $"_alias: ${join(ns.aliases, ", ")}_" }
        wdoc_repeater { each = match ns.description { none => [], d => [d] }  as = :d  p $"${d}" }
        wdoc_repeater { each = match len(ns.args) { 0 => [], _ => [true] }  as = :_a
          table { header = ["Argument", "Required", "Description"]  rows = map(ns.args, fn(a: CliArg) -> list<utf8> { [$"${a.name}${match a.variadic { true => "…", _ => "" }}", match a.required { true => "required", _ => "optional" }, a.description ?? "—"] }) }
        }
        wdoc_repeater { each = match len(ns.switches) { 0 => [], _ => [true] }  as = :_s
          table { header = ["Switch", "Value", "Description"]  rows = map(ns.switches, fn(sw: CliSwitch) -> list<utf8> { [$"${match sw.short { none => "", s => $"${s}, " }}${sw.long}", sw.value_name ?? "—", sw.description ?? "—"] }) }
        }
        wdoc_repeater { each = ns.examples  as = :ex  code $"${ex.lang ?? "text"}" { source = ex.code } }
        wdoc_repeater { each = match ns.remarks { none => [], r => [r] }  as = :r  p $"**Remarks:** ${r}" }
      }
    }
  }
}

// --- references/glossary.md -------------------------------------------------
page glossary_ref { sites = [:skill]  title = "Glossary"
  h1 $"${topic.name} — glossary"
  wdoc_repeater { each = match len(terms) { 0 => [], _ => [true] }  as = :_g
    table {
      header = ["Term", "Definition", "Aliases"]
      rows = map(terms, fn(t: Term) -> list<utf8> { [t.term, t.definition, join(t.aliases, ", ")] })
    }
  }
}

// --- references/related.md --------------------------------------------------
page related_ref { sites = [:skill]  title = "Related skills"
  h1 $"${topic.name} — related skills"
  wdoc_repeater { each = match len(refs) { 0 => [true], _ => [] }  as = :_n
    p "No related wskills declared."
  }
  wdoc_repeater { each = refs  as = :r
    p $"**${r.name}**${match r.relation { none => "", rel => $" — ${rel}" }} ${match r.status { "planned" => "_(planned — stub)_", _ => "" }}${match r.url { none => "", u => $" · ${u}" }}"
  }
}

// --- references/assets.md + the shipped scripts/assets ----------------------
page assets_ref { sites = [:skill]  title = "Bundled files"
  h1 $"${topic.name} — bundled files"
  wdoc_repeater { each = match bundled_count { 0 => [true], _ => [] }  as = :_n
    p "No files bundled with this skill."
  }
  wdoc_repeater { each = match len(skill_scripts) { 0 => [], _ => [true] }  as = :_s
    h2 "Scripts"
    p  "Runnable scripts shipped under the skill's `scripts/` directory."
  }
  wdoc_repeater { each = skill_scripts  as = :s
    h3 $"${s.name}"
    p  $"${s.description}"
    p  $"**Run:** `${s.usage}` — shipped to `scripts/${s.name}`."
    file $"../../${s.source}" { dir = "scripts" }
  }
  wdoc_repeater { each = match len(skill_assets) { 0 => [], _ => [true] }  as = :_a
    h2 "Data files"
    p  "Static data shipped under `assets/`."
  }
  wdoc_repeater { each = skill_assets  as = :a
    h3 $"${a.name}"
    p  $"${a.description} — shipped to `assets/${a.name}`."
    file $"../../${a.source}" { dir = "assets" }
  }
}
