// Book Reference landing — a force-directed graph of every unit at the top,
// then a per-kind "index coverage" table (each note and how many indexes pin
// it). Each table is gated so empty kinds don't appear. Imported by
// book/main.wcl. Not standalone-checkable (resolves the `concepts` /
// `entities` / `facts` / `procedures` / `indexes` lets defined in main.wcl).

// Record for the graph diagram's computed `edges = [...]` field. Node ids are
// the raw unit ids, so a `related` id maps straight to its node. The diagram's
// Edge connection is `@dynamic`, so an endpoint naming a missing node is dropped
// with a build warning rather than failing the build.
type GraphEdge { source: utf8  destination: utf8 }

// One edge per (unit, related-id) pair, across all four unit kinds.
let note_edges = flatten([
  flatten(map(concepts,   fn(c: Concept)   -> list<GraphEdge> { map(c.related, fn(r: identifier) -> GraphEdge { { source: $"${c.id}", destination: $"${r}" } }) })),
  flatten(map(entities,   fn(e: Entity)    -> list<GraphEdge> { map(e.related, fn(r: identifier) -> GraphEdge { { source: $"${e.id}", destination: $"${r}" } }) })),
  flatten(map(facts,      fn(f: Fact)      -> list<GraphEdge> { map(f.related, fn(r: identifier) -> GraphEdge { { source: $"${f.id}", destination: $"${r}" } }) })),
  flatten(map(procedures, fn(p: Procedure) -> list<GraphEdge> { map(p.related, fn(r: identifier) -> GraphEdge { { source: $"${p.id}", destination: $"${r}" } }) })),
])

// Every unit id pinned by an index — each index's own `related`, plus one level
// of nested child indexes (`schema/base.wcl` nests indexes one level). The
// "Index coverage" tables below count, per note, how many entries here equal its
// id: i.e. how many times it is pinned into the curated navigation.
let index_refs = flatten([
  flatten(map(book_indexes, fn(i: Index) -> list<identifier> { i.related })),
  flatten(map(book_indexes, fn(i: Index) -> list<identifier> {
    flatten(map(i.children, fn(c: Index) -> list<identifier> { c.related }))
  })),
])

// How many index `related` lists (top-level or nested) reference `id`.
fn index_link_count(id: identifier) -> i64 {
  len(filter(index_refs, fn(t: identifier) -> bool { t == id }))
}

// Node colours for the graph: paint each circle by note type, and give the
// label white text so it stays legible on the fill in both light and dark mode
// (the default label colour is dark, which vanishes in dark mode). Element-
// qualified selectors split the shared per-node class across circle vs label.
stylesheet "graph-node-colours" {
  css = <<CSS
circle.gnode-concept { fill: #2563eb }
circle.gnode-entity  { fill: #b45309 }
circle.gnode-fact    { fill: #15803d }
circle.gnode-process { fill: #7c3aed }
text.gnode-concept, text.gnode-entity, text.gnode-fact, text.gnode-process { fill: #ffffff }
CSS
}

page reference_page {
  h1 "WSkill Graph"
  p  "Everything about this topic, mapped below as a force-directed graph and listed beneath it."
  p  "Each circle is a note (click it to open its page) and each line is a `related` link — colour-coded by type (**concepts** blue, **entities** amber, **facts** green, **processes** purple). Scroll to zoom and drag to pan."
  p  "Curious how the *skill* projection is wired? The **Skill preview** sidebar button opens a graph of the skill's pages (`SKILL.md` + `references/*`) and each page's generated Markdown."
  diagram {
    width    = 960
    height   = 640
    layout   = :force
    pan_zoom = true
    zoom_min = 1.0
    zoom_max = 4.0
    link_distance = 150.0
    routing  = :straight
    desc = "Force-directed graph of every wskill note and its related links."

    // The label is the node's inline (positional) value — an `@inline(0)` field
    // set by name (`text = …`) is not picked up as the shape label. Colour comes
    // from a per-type `class`; the `graph-node-colours` stylesheet paints the
    // circle and gives the label white text (legible in light and dark mode).
    wdoc_repeater { each = concepts   as = :c  node $"${c.name}"  { id = c.id  link = $"concept_${c.id}"  class = ["gnode-concept"]  width = 120.0  height = 120.0 } }
    wdoc_repeater { each = entities   as = :e  node $"${e.name}"  { id = e.id  link = $"entity_${e.id}"   class = ["gnode-entity"]   width = 120.0  height = 120.0 } }
    wdoc_repeater { each = facts      as = :f  node $"${f.title}" { id = f.id  link = $"fact_${f.id}"     class = ["gnode-fact"]     width = 120.0  height = 120.0 } }
    wdoc_repeater { each = procedures as = :p  node $"${p.title}" { id = p.id  link = $"process_${p.id}"  class = ["gnode-process"]  width = 120.0  height = 120.0 } }

    edges = note_edges
  }

  h2 "Index coverage"
  p  "How many times each note is pinned into a curated index (counting nested indexes). A `0` means the note isn't reachable from the index navigation yet."

  wdoc_repeater { each = match len(concepts) { 0 => [], _ => [true] }  as = :_tc
    h3 "Concepts"
    table {
      header = ["Concept", "Index links"]
      rows = map(concepts, fn(c: Concept) -> list<utf8> {
        [$"[**${c.name}**](concept_${c.id})", $"${index_link_count(c.id)}"]
      })
    }
  }
  wdoc_repeater { each = match len(entities) { 0 => [], _ => [true] }  as = :_te
    h3 "Entities"
    table {
      header = ["Entity", "Index links"]
      rows = map(entities, fn(e: Entity) -> list<utf8> {
        [$"[**${e.name}**](entity_${e.id})", $"${index_link_count(e.id)}"]
      })
    }
  }
  wdoc_repeater { each = match len(facts) { 0 => [], _ => [true] }  as = :_tf
    h3 "Facts"
    table {
      header = ["Fact", "Index links"]
      rows = map(facts, fn(f: Fact) -> list<utf8> {
        [$"[**${f.title}**](fact_${f.id})", $"${index_link_count(f.id)}"]
      })
    }
  }
  wdoc_repeater { each = match len(procedures) { 0 => [], _ => [true] }  as = :_tp
    h3 "Processes"
    table {
      header = ["Process", "Index links"]
      rows = map(procedures, fn(p: Procedure) -> list<utf8> {
        [$"[**${p.title}**](process_${p.id})", $"${index_link_count(p.id)}"]
      })
    }
  }
}
