// Book Concepts index — links to each concept's generated page (via the shared
// type_index component). Imported by book/main.wcl (resolves its `concepts`
// let). Not standalone-checkable.

page concepts_page {
  type_index {
    heading = "Concepts"
    intro   = "Each concept has its own page — open one from the list below or the sidebar."
    items   = map(concepts, fn(c: Concept) -> utf8 { $"[**${c.name}**](concept_${c.id}) — ${c.summary}" })
  }
}
