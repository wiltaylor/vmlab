#cloud-config
# NoCloud seed (read by FreeBSD's nuageinit from the CIDATA volume). Creates
# the vmlab login and installs + enables the QEMU guest agent so lab clones
# come up "ready". On lab clones there is no seed, so nuageinit does nothing.
hostname: freebsd
users:
  - name: vmlab
    groups: wheel
    shell: /bin/sh
    lock_passwd: false
    passwd: "$6$R8.CmeE4fbYGFJV0$AZ9vFu4sswfw7JCOWid1xz8mu.x2w/dg6TIswciEABLFl0lyI5pD1G1CaUSMe74BaDl3mCOq2Sg6MBIQV5ql91"
ssh_pwauth: true
package_update: true
packages:
  - qemu-guest-agent
runcmd:
  - sysrc qemu_guest_agent_enable=YES
  - service qemu-guest-agent start
