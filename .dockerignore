# Keep the build context small — the Containerfile builds the frontend and
# both binaries from source; everything below is build output, VCS, or
# runtime state that the image must not ship.
target/
.git/
.github/
web-ui/node_modules/
web-ui/dist/
docs/_site/
docs/wskills/*/out/
**/.vmlab/
docker/lab/.vmlab/
